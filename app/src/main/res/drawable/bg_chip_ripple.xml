<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33000000">

    <item>
        <selector>

            <!-- SELECIONADO -->
            <item android:state_checked="true">
                <shape>
                    <solid android:color="#22C55E"/>
                    <corners android:radius="50dp"/>
                </shape>
            </item>

            <!-- NORMAL -->
            <item>
                <shape>
                    <solid android:color="#E5E7EB"/>
                    <corners android:radius="50dp"/>
                </shape>
            </item>

        </selector>
    </item>

</ripple>