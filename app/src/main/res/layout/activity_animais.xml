<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTEÚDO PRINCIPAL -->
    <LinearLayout
        android:id="@+id/layoutPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/gray_background">

        <!-- TOOLBAR (MENU HAMBURGUER) -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:title="Animals"
            android:backgroundTint="@color/kids_orange"
            android:titleTextColor="@android:color/white"/>

        <!-- CONTEÚDO DA TELA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Que tipo de animal vamos conhecer hoje?"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1F2A37"
                android:layout_marginBottom="16dp"/>

            <RadioGroup
                android:id="@+id/radioGroupCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbTerrestre"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Terrestres"
                    android:gravity="center"
                    android:background="@drawable/bg_chip_ripple"
                    android:textColor="@color/text_selector"
                    android:button="@null"/>

                <RadioButton
                    android:id="@+id/rbAereo"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Aéreos"
                    android:gravity="center"
                    android:background="@drawable/bg_chip_ripple"
                    android:textColor="@color/text_selector"
                    android:button="@null"/>

                <RadioButton
                    android:id="@+id/rbAquatico"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Marinhos"
                    android:gravity="center"
                    android:background="@drawable/bg_chip_ripple"
                    android:textColor="@color/text_selector"
                    android:button="@null"/>
            </RadioGroup>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAnimais"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="16dp"/>

        </LinearLayout>
    </LinearLayout>

    <!-- MENU LATERAL -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_lateral"/>

</androidx.drawerlayout.widget.DrawerLayout>